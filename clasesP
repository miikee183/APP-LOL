    fun playMusic(audioResource: Int) {
        currentMediaPlayer?.apply {
            stop()
            release()
        }
        currentMediaPlayer = MediaPlayer.create(context, audioResource).apply {
            isLooping = true
            start()
        }
    }

    // Reproducir "rise.mp3" al iniciar
    LaunchedEffect(Unit) {
        playMusic(R.raw.rise)
    }

    // Liberar recursos al cerrar
    DisposableEffect(Unit) {
        onDispose {
            currentMediaPlayer?.apply {
                stop()
                release()
            }
        }
    }

    // Navegación entre pantallas
    when (val screen = currentScreen) {
        is Screen.MainMenu -> {
            MainMenuScreen(
                regions = regions,
                onRegionClick = { region ->
                    currentScreen = Screen.RegionDetail(region)
                    playMusic(region.audioResource)
                }
            )
        }
        is Screen.RegionDetail -> {
            RegionDetailScreen(
                region = screen.region,
                onBackClick = {
                    currentScreen = Screen.MainMenu
                    playMusic(R.raw.rise)
                }
            )
        }
    }
}

@OptIn(ExperimentalMaterial3Api::class)
@Composable
fun MainMenuScreen(
    regions: List<Region>,
    onRegionClick: (Region) -> Unit
) {
    Column(
        modifier = Modifier
            .fillMaxSize()
            .padding(16.dp)
    ) {
        // Título
        Text(
            text = "REGIONES DE RUNETERRA",
            fontSize = 28.sp,
            fontWeight = FontWeight.Bold,
            color = Color(0xFFd4af37),
            modifier = Modifier
                .padding(bottom = 8.dp)
                .align(Alignment.CenterHorizontally)
        )

        Text(
            text = "♪ Rise",
            fontSize = 14.sp,
            color = Color(0xFF888888),
            modifier = Modifier
                .padding(bottom = 24.dp)
                .align(Alignment.CenterHorizontally)
        )

        // Lista de regiones
        LazyColumn(
            verticalArrangement = Arrangement.spacedBy(12.dp)
        ) {
            items(regions) { region ->
                RegionCard(
                    region = region,
                    onClick = { onRegionClick(region) }
                )
            }
        }
    }
}

@OptIn(ExperimentalMaterial3Api::class)
@Composable
fun RegionDetailScreen(
    region: Region,
    onBackClick: () -> Unit
) {
    Column(
        modifier = Modifier
            .fillMaxSize()
            .background(Color(0xFF1a1a2e))
    ) {
        // Barra superior
        TopAppBar(
            title = {
                Text(
                    text = region.name,
                    fontWeight = FontWeight.Bold
                )
            },
            navigationIcon = {
                IconButton(onClick = onBackClick) {
                    Icon(
                        imageVector = Icons.Default.ArrowBack,
                        contentDescription = "Volver",
                        tint = Color.White
                    )
                }
            },
            colors = TopAppBarDefaults.topAppBarColors(
                containerColor = region.color,
                titleContentColor = Color.White
            )
        )

        // Contenido
        Column(
            modifier = Modifier
                .fillMaxSize()
                .verticalScroll(rememberScrollState())
                .padding(20.dp),
            verticalArrangement = Arrangement.spacedBy(24.dp)
        ) {
            // Descripción
            Card(
                colors = CardDefaults.cardColors(
                    containerColor = Color(0xFF16213e)
                ),
                shape = RoundedCornerShape(12.dp)
            ) {
                Column(
                    modifier = Modifier.padding(20.dp)
                ) {
                    Text(
                        text = "DESCRIPCIÓN",
                        fontSize = 14.sp,
                        fontWeight = FontWeight.Bold,
                        color = region.color,
                        modifier = Modifier.padding(bottom = 12.dp)
                    )
                    Text(
                        text = region.description,
                        fontSize = 16.sp,
                        color = Color.White,
                        lineHeight = 24.sp
                    )
                }
            }

            // Características
            Card(
                colors = CardDefaults.cardColors(
                    containerColor = Color(0xFF16213e)
                ),
                shape = RoundedCornerShape(12.dp)
            ) {
                Column(
                    modifier = Modifier.padding(20.dp)
                ) {
                    Text(
                        text = "CARACTERÍSTICAS",
                        fontSize = 14.sp,
                        fontWeight = FontWeight.Bold,
                        color = region.color,
                        modifier = Modifier.padding(bottom = 12.dp)
                    )
                    region.characteristics.forEach { characteristic ->
                        Row(
                            modifier = Modifier.padding(vertical = 6.dp)
                        ) {
                            Box(
                                modifier = Modifier
                                    .size(8.dp)
                                    .background(
                                        color = region.color,
                                        shape = RoundedCornerShape(4.dp)
                                    )
                                    .align(Alignment.CenterVertically)
                            )
                            Spacer(modifier = Modifier.width(12.dp))
                            Text(
                                text = characteristic,
                                fontSize = 15.sp,
                                color = Color.White
                            )
                        }
                    }
                }
            }

            // Campeones destacados
            Card(
                colors = CardDefaults.cardColors(
                    containerColor = Color(0xFF16213e)
                ),
                shape = RoundedCornerShape(12.dp)
            ) {
                Column(
                    modifier = Modifier.padding(20.dp)
                ) {
                    Text(
                        text = "CAMPEONES DESTACADOS",
                        fontSize = 14.sp,
                        fontWeight = FontWeight.Bold,
                        color = region.color,
                        modifier = Modifier.padding(bottom = 12.dp)
                    )
                    Text(
                        text = region.champions,
                        fontSize = 16.sp,
                        color = Color.White
                    )
                }
            }

            // Indicador de música
            Card(
                colors = CardDefaults.cardColors(
                    containerColor = region.color.copy(alpha = 0.3f)
                ),
                shape = RoundedCornerShape(12.dp)
            ) {
                Row(
                    modifier = Modifier
                        .fillMaxWidth()
                        .padding(16.dp),
                    verticalAlignment = Alignment.CenterVertically
                ) {
                    Text(
                        text = "♪",
                        fontSize = 24.sp,
                        color = Color.White
                    )
                    Spacer(modifier = Modifier.width(12.dp))
                    Text(
                        text = "Reproduciendo música de ${region.name}",
                        fontSize = 14.sp,
                        color = Color.White
                    )
                }
            }
        }
    }
}

@Composable
fun RegionCard(
    region: Region,
    onClick: () -> Unit
) {
    Card(
        modifier = Modifier
            .fillMaxWidth()
            .clickable(onClick = onClick),
        colors = CardDefaults.cardColors(
            containerColor = Color(0xFF16213e)
        ),
        elevation = CardDefaults.cardElevation(
            defaultElevation = 4.dp
        ),
        shape = RoundedCornerShape(12.dp)
    ) {
        Row(
            modifier = Modifier
                .fillMaxWidth()
                .padding(20.dp),
            verticalAlignment = Alignment.CenterVertically
        ) {
            Box(
                modifier = Modifier
                    .size(12.dp)
                    .background(
                        color = region.color,
                        shape = RoundedCornerShape(6.dp)
                    )
            )

            Spacer(modifier = Modifier.width(16.dp))

            Text(
                text = region.name,
                fontSize = 18.sp,
                fontWeight = FontWeight.Medium,
                color = Color.White
            )

            Spacer(modifier = Modifier.weight(1f))

            Text(
                text = "→",
                fontSize = 20.sp,
                color = region.color
            )
        }
    }
}
