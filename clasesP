// Modelo de datos para las regiones
data class Region(
    val name: String,
    val audioResource: Int,
    val color: Color,
    val description: String,
    val characteristics: List<String>,
    val champions: String
)

sealed class Screen {
    object MainMenu : Screen()
    data class RegionDetail(val region: Region) : Screen()
}

